PORT=4000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/SMIC_pro
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=SMIC_pro
MYSQL_PORT=3306

# PostgreSQL (for docker-compose)
PGHOST=localhost
PGUSER=postgres
PGPASSWORD=change_me_to_a_strong_password
PGDATABASE=SMIC_pro
PGPORT=5432

# Auth - JWT_SECRET must be at least 32 characters
JWT_SECRET=replace_with_a_strong_secret_at_least_32_chars_long

# API Keys
OPENAI_API_KEY=sk-proj-your-openai-key-here
INSTAGRAM_API_KEY=
YOUTUBE_API_KEY=your-youtube-api-key-here
FACEBOOK_API_KEY=your-facebook-api-key-here

# News & Content Sources
WAY2NEWS_API_KEY=
NEWS_API_KEY=your-news-api-key-here

# CORS - comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Docker credentials
MONGO_USER=admin
MONGO_PASSWORD=change_me_to_a_strong_password
PGADMIN_EMAIL=admin@SMIC.dev
PGADMIN_PASSWORD=change_me_to_a_strong_password

# AWS S3 (media storage)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=SMIC-pro-media

# Redis (Bull job queue)
REDIS_URL=redis://localhost:6379

# Media upload limits
MAX_UPLOAD_MB=50

# Supabase (frontend)
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=
